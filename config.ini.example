[discord]
token = YOUR_BOT_TOKEN_HERE
message_content_intent = true
guild_id = 123456789012345678
panel_channel_id = 123456789012345678

[tickets]
thread_name_prefix = ticket
auto_archive_duration = 1440
delete_closed_threads_after_hours = 72
allow_thread_owner_close = true
allow_thread_owner_reopen = true
close_requires_staff = false
interaction_delete_after_seconds = 30
# Comma-separated tag names to hide from the in-thread Quick Tags buttons.
# These tags will still be available via slash commands and the dashboard.
hidden_thread_tag_names =
embed_color = 0x5865F2

[support]
role_ids = 123456789012345678,234567890123456789

[logs]
transcript_channel_id = 123456789012345678
save_txt_transcript = true
save_html_transcript = true

[database]
host = 127.0.0.1
port = 3306
user = ticketbot
password = CHANGE_ME
name = discord_tickets
minsize = 1
maxsize = 10
charset = utf8mb4

[dashboard]
enabled = true
host = 127.0.0.1
port = 8000
secret_key = CHANGE_ME_TO_A_LONG_RANDOM_STRING
base_url = http://127.0.0.1:8000
discord_client_id = YOUR_DISCORD_APPLICATION_CLIENT_ID
discord_client_secret = YOUR_DISCORD_APPLICATION_CLIENT_SECRET
discord_redirect_uri = http://127.0.0.1:8000/auth/discord/callback
admin_user_ids = 123456789012345678

[servers]
Survival Server = 111111111111111111
Skyblock Server = 222222222222222222
Creative Server = 333333333333333333

[dashboard_role_access]
123456789012345678 = 111111111111111111
234567890123456789 = 222222222222222222,333333333333333333
345678901234567890 = *
