[discord]
token = YOUR_BOT_TOKEN_HERE
guild_id = 123456789012345678
panel_channel_id = 123456789012345678

[tickets]
thread_name_prefix = ticket
auto_archive_duration = 1440
delete_closed_threads_after_hours = 72
allow_thread_owner_close = true
allow_thread_owner_reopen = false
prevent_duplicate_open_tickets = true
close_requires_staff = false
embed_color = 0x5865F2

[support]
role_ids = 123456789012345678,234567890123456789

[logs]
transcript_channel_id = 123456789012345678
save_txt_transcript = true
save_html_transcript = true

[database]
host = 127.0.0.1
port = 3306
user = ticketbot
password = CHANGE_ME
name = discord_tickets
minsize = 1
maxsize = 10
charset = utf8mb4

[dashboard]
enabled = true
host = 127.0.0.1
port = 8000
secret_key = CHANGE_ME_TO_A_LONG_RANDOM_STRING
username = admin
password = CHANGE_ME
base_url = http://127.0.0.1:8000

[servers]
Survival Server = 111111111111111111
Skyblock Server = 222222222222222222
Creative Server = 333333333333333333
